<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Bootstrap "card shadow-sm border-0" equivalent -->
    <style name="DashboardCard">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardBackgroundColor">@color/colorWhite</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="SectionLabel">
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/colorMuted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
    </style>


</resources>